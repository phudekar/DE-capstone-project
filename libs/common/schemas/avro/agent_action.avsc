{
  "type": "record",
  "name": "AgentAction",
  "namespace": "com.deproject.raw.agentactions",
  "fields": [
    {"name": "event_type", "type": "string"},
    {"name": "event_id", "type": "string"},
    {"name": "timestamp", "type": "string"},
    {"name": "agent_id", "type": "string"},
    {"name": "agent_type", "type": {"type": "enum", "name": "AgentType", "symbols": ["RetailTrader", "InstitutionalInvestor", "MarketMaker", "HighFrequencyTrader"]}},
    {"name": "symbol", "type": "string"},
    {"name": "action", "type": "string"},
    {"name": "decision_factors", "type": {"type": "array", "items": "string"}}
  ]
}
