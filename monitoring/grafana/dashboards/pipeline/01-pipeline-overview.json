{
  "uid": "pipeline-overview",
  "title": "Pipeline Overview",
  "tags": ["pipeline", "overview"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Data Freshness by Layer",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "max by (layer) (dagster_asset_freshness_seconds)",
          "legendFormat": "{{layer}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 300},
              {"color": "red", "value": 900}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Trade Messages per Second",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "rate(kafka_bridge_ws_messages_received_total[1m])",
          "legendFormat": "WS messages received"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "ops"}
      }
    },
    {
      "id": 3,
      "title": "Pipeline Component Health",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 0},
      "targets": [
        {
          "expr": "up{job=~\"graphql-api|kafka-bridge|pushgateway|node-exporter|cadvisor\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "GraphQL Cache Hit Rate (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "rate(graphql_cache_hits_total[5m]) / (rate(graphql_cache_hits_total[5m]) + rate(graphql_cache_misses_total[5m])) * 100",
          "legendFormat": "cache hit rate"
        },
        {
          "expr": "graphql_active_requests",
          "legendFormat": "active requests"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percent", "max": 100}
      }
    },
    {
      "id": 5,
      "title": "Bridge Errors (last 1h)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 0},
      "targets": [
        {
          "expr": "sum(increase(kafka_bridge_validation_failures_total[1h])) or vector(0)",
          "legendFormat": "Validation failures"
        },
        {
          "expr": "sum(increase(kafka_bridge_serialization_failures_total[1h])) or vector(0)",
          "legendFormat": "Serialization failures"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    }
  ]
}
