{
  "uid": "data-quality",
  "title": "Data Quality",
  "tags": ["data-quality", "observability"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {"from": "now-3h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Data Freshness by Asset",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "description": "Requires dagster prometheus_metrics_sensor to be enabled. Pushes dagster_asset_freshness_seconds via pushgateway.",
      "targets": [
        {
          "expr": "dagster_asset_freshness_seconds",
          "legendFormat": "{{asset}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 300},
              {"color": "red", "value": 900}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Bridge Message Throughput",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "rate(kafka_bridge_ws_messages_received_total[5m])",
          "legendFormat": "messages/sec (5m avg)"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 3,
      "title": "Bridge Error Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "rate(kafka_bridge_validation_failures_total[5m])",
          "legendFormat": "validation failures"
        },
        {
          "expr": "rate(kafka_bridge_serialization_failures_total[5m])",
          "legendFormat": "serialization failures"
        },
        {
          "expr": "rate(kafka_bridge_dlq_produced_total[5m])",
          "legendFormat": "DLQ messages"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "GraphQL Cache Effectiveness",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "rate(graphql_cache_hits_total[5m])",
          "legendFormat": "cache hits/sec"
        },
        {
          "expr": "rate(graphql_cache_misses_total[5m])",
          "legendFormat": "cache misses/sec"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 5,
      "title": "Scrape Target Health",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}
          ]
        }
      }
    }
  ]
}
