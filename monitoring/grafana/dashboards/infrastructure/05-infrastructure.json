{
  "uid": "infrastructure",
  "title": "Infrastructure",
  "tags": ["infrastructure", "host"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage by Host (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100}}
    },
    {
      "id": 2,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "used"
        },
        {
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "available"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 3,
      "title": "Disk Available",
      "type": "stat",
      "gridPos": {"h": 4, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay\"}",
          "legendFormat": "{{instance}} {{mountpoint}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 4,
      "title": "Docker Total CPU Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "description": "Total CPU used by all Docker containers (Colima cgroup aggregate).",
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{id=\"/docker\"}[1m]) * 100",
          "legendFormat": "docker total"
        },
        {
          "expr": "rate(container_cpu_usage_seconds_total{id=\"/system.slice/containerd.service\"}[1m]) * 100",
          "legendFormat": "containerd"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent"}}
    },
    {
      "id": 5,
      "title": "Docker Total Memory Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "description": "Total memory used by all Docker containers (Colima cgroup aggregate). Use 'docker stats' for per-container breakdown.",
      "targets": [
        {
          "expr": "container_memory_usage_bytes{id=\"/docker\"}",
          "legendFormat": "docker total"
        },
        {
          "expr": "machine_memory_bytes",
          "legendFormat": "VM total"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 6,
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*\"}[1m])",
          "legendFormat": "rx {{device}}"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*\"}[1m])",
          "legendFormat": "tx {{device}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "id": 7,
      "title": "CPU Usage by Container",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{id=~\"/docker/.*\"}[1m]) * 100",
          "legendFormat": "{{id}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent"}}
    },
    {
      "id": 8,
      "title": "Memory Usage by Container",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "targets": [
        {
          "expr": "container_memory_usage_bytes{id=~\"/docker/.*\"}",
          "legendFormat": "{{id}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    }
  ]
}
