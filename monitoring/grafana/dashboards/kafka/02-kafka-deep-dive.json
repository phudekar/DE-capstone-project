{
  "uid": "kafka-deep-dive",
  "title": "Kafka Deep Dive",
  "tags": ["kafka"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "15s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Bridge Messages Received / sec",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "rate(kafka_bridge_ws_messages_received_total[1m])",
          "legendFormat": "messages/sec"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 2,
      "title": "Bridge Processing Latency",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "rate(kafka_bridge_latency_seconds_sum[1m]) / rate(kafka_bridge_latency_seconds_count[1m])",
          "legendFormat": "avg latency"
        },
        {
          "expr": "histogram_quantile(0.95, rate(kafka_bridge_latency_seconds_bucket[1m]))",
          "legendFormat": "p95 latency"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 3,
      "title": "Validation & Serialization Failures / sec",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "rate(kafka_bridge_validation_failures_total[1m])",
          "legendFormat": "validation failures"
        },
        {
          "expr": "rate(kafka_bridge_serialization_failures_total[1m])",
          "legendFormat": "serialization failures"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 4,
      "title": "Dead Letter Queue Messages (5m)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "increase(kafka_bridge_dlq_produced_total[5m])",
          "legendFormat": "DLQ messages"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 5,
      "title": "WebSocket Reconnects",
      "type": "stat",
      "gridPos": {"h": 4, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "kafka_bridge_ws_reconnects_total",
          "legendFormat": "total reconnects"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 20}
            ]
          }
        }
      }
    }
  ]
}
